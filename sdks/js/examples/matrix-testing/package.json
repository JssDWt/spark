    "prettier": "^3.5.1",
    "ts-jest": "^29.4.0",
    "tsx": "^4.20.3",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@buildonspark/lrc20-sdk": "0.0.32",
    "@buildonspark/spark-sdk": "workspace:^",
    "@lightsparkdev/core": "^1.3.0",
    "spark-sdk-29": "npm:@buildonspark/spark-sdk@0.1.29",
