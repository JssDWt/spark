    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^7.0.3",
    "eslint": "^9.25.0",
    "globals": "^15.15.0",
    "prettier": "^3.7.4",
    "typescript": "^5.7.3",
    "vite": "^6.2.0"
