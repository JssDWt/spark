{
  "name": "spark-browser-extension",
  "version": "0.0.65",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "yarn tsc && rm -rf dist && yarn build:all",
    "build:all": "node build.mjs --all",
    "build:chrome": "node build.mjs",
    "build:firefox": "node build.mjs --firefox",
    "watch": "node build.mjs --all --watch",
    "watch:all": "node build.mjs --all --watch",
    "watch:chrome": "node build.mjs --watch",
    "watch:firefox": "node build.mjs --firefox --watch",
    "format:fix": "prettier . --write",
    "format": "prettier . --check",
    "lint:fix": "eslint --fix src build.mjs",
    "lint": "eslint src build.mjs"
  },
  "dependencies": {
    "@buildonspark/spark-sdk": "0.8.2"
  },
  "devDependencies": {
    "@lightsparkdev/eslint-config": "^0.0.1",
    "@types/chrome": "^0.0.276",
    "esbuild": "^0.25.0",
    "eslint": "^9.25.0",
    "prettier": "^3.7.4",
    "typescript": "^5.7.3"
  }
}
