{
  "name": "@buildonspark/spark-bare-app",
  "version": "0.1.39",
  "private": true,
  "type": "module",
  "scripts": {
    "format:fix": "prettier . --write",
    "format": "prettier . --check",
    "lint:fix": "eslint --fix *.js *.mjs scripts",
    "lint": "eslint *.js *.mjs scripts",
    "get-or-create-wallet": "node ./scripts/run-script.mjs get-or-create-wallet",
    "get-static-deposit-address": "node ./scripts/run-script.mjs get-static-deposit-address",
    "auto-claim-static-deposit": "node ./scripts/run-script.mjs auto-claim-static-deposit",
    "create-lightning-invoice": "node ./scripts/run-script.mjs create-lightning-invoice",
    "transfer": "node ./scripts/run-script.mjs transfer",
    "run": "node ./scripts/run-script.mjs",
    "run:local": "cross-env NODE_ENV=development NETWORK=LOCAL ../../scripts/with-local-routing.sh node ./scripts/run-script.mjs",
    "run:mainnet": "cross-env NODE_ENV=production NETWORK=MAINNET node ./scripts/run-script.mjs",
    "run:dev": "cross-env NODE_ENV=development NETWORK=REGTEST CONFIG_FILE=../../private/config/dev-regtest-config.json node ./scripts/run-script.mjs",
    "run:dev:mainnet": "cross-env NODE_ENV=development NETWORK=MAINNET CONFIG_FILE=../../private/config/dev-mainnet-config.json node ./scripts/run-script.mjs"
  },
  "dependencies": {
    "@buildonspark/bare": "0.0.69",
    "@buildonspark/spark-sdk": "0.8.1",
    "bare": "^1.28.4",
    "bare-runtime": "^1.28.4"
  },
  "devDependencies": {
    "@lightsparkdev/eslint-config": "^0.0.1",
    "cross-env": "^7.0.3",
    "eslint": "^9.25.0",
    "prettier": "^3.7.4",
    "typescript": "^5.7.3"
  }
}
